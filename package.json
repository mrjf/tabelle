{
  "name": "@mrjf/tabelle",
  "version": "0.3.1",
  "description": "a single-page, URL-addressable list table — sort, filter, group; every view is an address",
  "type": "module",
  "main": "listtable.js",
  "exports": {
    ".": "./listtable.js",
    "./dateline": "./dateline.js",
    "./themes/swiss.css": "./themes/swiss.css"
  },
  "files": [
    "listtable.js",
    "dateline.js",
    "themes"
  ],
  "scripts": {
    "build:demo": "node scripts/build-demo.js",
    "demo": "node scripts/build-demo.js && node scripts/serve-demo.js",
    "test": "node --test",
    "prepublishOnly": "npm test && npm run build:demo"
  },
  "devDependencies": {
    "jsdom": "^24.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mrjf/tabelle.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
